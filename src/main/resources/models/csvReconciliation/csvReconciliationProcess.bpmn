    <scriptTask id="ScriptTask_1" name="Find Missing Work Itms" flowable:async="true" scriptFormat="groovy" flowable:resultVariable="test" flowable:autoStoreVariables="true">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[import java.time.*
import java.time.temporal.ChronoUnit
import com.fasterxml.jackson.databind.ObjectMapper

def mapper = new ObjectMapper()

def auths = flw.json.stringToJson(execution.getVariable("workItems"))
def members = flw.json.stringToJson(execution.getVariable("members"))
def buInfo = flw.json.stringToJson(execution.getVariable("buInfo"))
def busPlan = flw.json.stringToJson(execution.getVariable("busPlan"))

def caseInstances = execution.getVariable("caseInstances")
def tasks = execution.getVariable("tasks")

def authsList = [] as List<Map>
def membersList = [] as List<Map>
def buInfoList = [] as List<Map>
def busPlanList = [] as List<Map>
  
def elements = auths.iterator()
while(elements.hasNext()) {
  authsList.add(mapper.convertValue(elements.next().get(), Map))
}

// members.iterator().forEachRemaining(it -> membersList.add(mapper.convertValue(it, Map)))
elements = members.iterator()
while(elements.hasNext()) {
  membersList.add(mapper.convertValue(elements.next().get(), Map))
}

elements = buInfo.iterator()
while(elements.hasNext()) {
  buInfoList.add(mapper.convertValue(elements.next().get(), Map))
}

elements = busPlan.iterator()
while(elements.hasNext()) {
  busPlanList.add(mapper.convertValue(elements.next().get(), Map))
}
execution.setVariable("authsList", authsList)
flw.setOutput("membersList", membersList)
flw.setOutput("buInfoList", buInfoList)
flw.setOutput("busPlanList", busPlanList)
def tables = [
    OH_RSAuthWList_tst     : authsList as List<Map>,
    OH_RS_wl_flow_TST      : mapper.convertValue(caseInstances.data, List) as List<Map>,
    OH_RS_WL_Flow_hist_tst : mapper.convertValue(tasks.data, List) as List<Map>,
    OH_RSUmvMbrs_tst       : membersList as List<Map>,
    OH_RS_BusinessUnit     : buInfoList as List<Map>,
    OH_RS_BusPlan_tst      : busPlanList as List<Map>,
]

def result = AuthReportBuilder.buildReport(tables)
flw.setOutput("result", result)
return result

/*
Assumed input shape:

tables = [
  OH_RSAuthWList_tst      : List<Map>,
  OH_RS_wl_flow_TST       : List<Map>,
  OH_RS_WL_Flow_hist_tst  : List<Map>,
  OH_RSUmvMbrs_tst        : List<Map>,
  OH_RS_BusinessUnit      : List<Map>,
  OH_RS_BusPlan_tst       : List<Map>
]

Each row is a Map like:
[
  authorizationnbr: "...",
  businessUnitCd: "...",
  memberId: "...",
  createdTs: "...",
  status: "...",
  requesMethodDesc: "...",
  sourceSystem: "...",
  user: "..."
]
*/

class AuthReportBuilder {

    static List<Map> buildReport(Map<String, List<Map>> tables) {
        List<Map> auths       = tables.OH_RSAuthWList_tst ?: []
        List<Map> wlFlow      = tables.OH_RS_wl_flow_TST ?: []
        List<Map> wlFlowHist  = tables.OH_RS_WL_Flow_hist_tst ?: []
        List<Map> members     = tables.OH_RSUmvMbrs_tst ?: []
        List<Map> businessU   = tables.OH_RS_BusinessUnit ?: []
        List<Map> busPlans    = tables.OH_RS_BusPlan_tst ?: []

        def now = Instant.now()

        // Indexes for faster lookups
		List<Map> wlFlowHistRows = WorklistJsonAdapter.normalizeRows(wlFlowHist)
		Map<String, List<Map>> wlFlowHistByAuth = wlFlowHistRows.groupBy { norm(it.authorizationnbr) }        
		List<Map> wlFlowRows = WorklistJsonAdapter.normalizeRows(wlFlow)
		Map<String, List<Map>> wlFlowByAuth = wlFlowRows.groupBy { norm(it.authorizationnbr) }
      	Map<String, Map> memberByCd = members.findAll { it.MemberCd != null }
                .collectEntries { [(norm(it.MemberCd)): it] }
        Map<String, Map> buByCode = businessU.findAll { it.bucode != null }
                .collectEntries { [(norm(it.bucode)): it] }
        Map<String, Map> busPlanByCode = busPlans.findAll { it.Code != null }
                .collectEntries { [(norm(it.Code)): it] }

        // Branch 1: Not Live In Cloud
        List<Map> notLiveInCloud = auths.findAll { a ->
            String authNbr = norm(a.authorizationnbr)
            Map e = busPlanByCode[norm(a.businessUnitCd)]
        
            boolean hasCaseInstance = !!(wlFlowByAuth[authNbr])
            boolean hasTask = !!(wlFlowHistByAuth[authNbr])
            boolean liveInCloudFalseOrNull = e == null || !isTrue(e.liveincloud)
            boolean noTccAuthNum = isBlank(a.tccAuthNum)
        
            hasCaseInstance && !hasTask && liveInCloudFalseOrNull && noTccAuthNum
        }.collect { a ->
            Map b = firstOrNull(wlFlowByAuth[norm(a.authorizationnbr)])
            Map c = memberByCd[norm(a.memberId)]
            Map d = buByCode[norm(a.businessUnitCd)]
            Map e = busPlanByCode[norm(a.businessUnitCd)]
        
            mergeRow(a, b, c, d, e, now)
        }

        // Branch 2: Live In Cloud
        List<Map> liveInCloud = auths.findAll { a ->
            String authNbr = norm(a.authorizationnbr)
            Map e = busPlanByCode[norm(a.businessUnitCd)]

            boolean noHistWorklist = !(wlFlowHistByAuth[authNbr])
            boolean noCurrentWorklist = !(wlFlowByAuth[authNbr])
            boolean liveInCloudTrue = e != null && isTrue(e.liveincloud)

            noHistWorklist && noCurrentWorklist && liveInCloudTrue
        }.collect { a ->
            Map b = firstOrNull(wlFlowHistByAuth[norm(a.authorizationnbr)])
            Map c = memberByCd[norm(a.memberId)]
            Map d = buByCode[norm(a.businessUnitCd)]
            Map e = busPlanByCode[norm(a.businessUnitCd)]

            mergeRow(a, b, c, d, e, now)
        }

        // union distinct *
        List<Map> unioned = distinctMaps(notLiveInCloud + liveInCloud)

        // Final WHERE block
        List<Map> filtered = unioned.findAll { row ->
            keepRow(row)
        }

        // Final select/order by age
        filtered.sort { a, b -> safeInt(a.age) <=> safeInt(b.age) }
    }

    static Map mergeRow(Map a, Map b, Map c, Map d, Map e, Instant now) {
        Map row = [:]
        row.putAll(a ?: [:])

        // Bring in selected fields from "b"
        row.realm = b?.realm
        row.workgroup = b?.workgroup
        row.groupassignment = b?.groupassignment
        row.AuthGroup = b?.AuthGroup
        row.crid = b?.crid
        row.crtask = b?.crtask

        // Bring in business unit fields from d
        if (d != null) {
            d.each { k, v ->
                // preserve original auth fields if names collide unless absent
                if (!row.containsKey(k) || row[k] == null) {
                    row[k] = v
                }
            }
        }

        row.newReqMthd = a?.requesMethodDesc
        row.PlanProduct = c?.PlanProduct
        row.BPcode2 = e?.Code
        row.liveincloud = e?.liveincloud
        row.BPLiveInCloud2a = isTrue(e?.liveincloud) ? 'Yes' : 'No'
        row.BPMarket2 = e?.market
        row.age = minutesSince(a?.createdTs, now)

        return row
    }

    static boolean keepRow(Map a) {
        String requesMethodDesc = up(a.RequesMethodDesc ?: a.requesMethodDesc)
        String newReqMthd = up(a.newReqMthd)
        String status = up(a.Status ?: a.status)
        String bu = str(a.businessUnitCd)
        String user = up(a.user)
        String sourceSystem = up(a.sourcesystem ?: a.sourceSystem)
        String liveInCloud = up(a.BPLiveInCloud2a)

        if (['OK TOC', 'OK CE'].contains(requesMethodDesc)) return false
        if (status == 'VOID') return false

        if (newReqMthd == 'MEDHOK' && liveInCloud == 'YES') return false
        if (bu == '78' && ['NCTRACK', 'NC TRACKS'].contains(user)) return false
        if (bu == '168' && ['NCTRACK', 'NC TRACKS'].contains(user)) return false
        if (['20', '12', '16', '77'].contains(bu) && sourceSystem.contains('TOC')) return false
        if (['260', '261', '262', '299'].contains(bu) && sourceSystem.trim() == 'WELLCARE') return false
        if (['TANGO', 'WELLSKY'].contains(newReqMthd) && liveInCloud == 'YES') return false
        if (newReqMthd == 'NIA' && liveInCloud == 'YES') return false
        if (['TOC', 'TURNINGPOINT', 'COASTAL CARE'].contains(newReqMthd)) return false
        if (bu == '77') return false
        if (bu == '262' && newReqMthd == 'SMG') return false
        if (newReqMthd == 'WELLCARE') return false
        if (newReqMthd == 'SMG') return false
        if (liveInCloud == 'YES') return false

        return true
    }

    static List<Map> distinctMaps(List<Map> rows) {
        Set<String> seen = new LinkedHashSet<>()
        List<Map> result = []
        rows.each { row ->
            String key = canonicalMapKey(row)
            if (seen.add(key)) {
                result << row
            }
        }
        result
    }

    static String canonicalMapKey(Map map) {
        def sorted = new TreeMap()
        sorted.putAll(map ?: [:])
        return sorted.collect { k, v -> "${k}=${v}" }.join('|')
    }

    static Integer minutesSince(def createdTs, Instant now) {
        Instant ts = toInstant(createdTs)
        if (ts == null) return null
        return ChronoUnit.MINUTES.between(ts, now) as Integer
    }

    static Instant toInstant(def val) {
        if (val == null) return null
        if (val instanceof Instant) return val
        if (val instanceof Date) return val.toInstant()

        String s = val.toString().trim()
        if (!s) return null

        // Try ISO first
        try { return Instant.parse(s) } catch (ignored) {}

        // Try local datetime
        try { return LocalDateTime.parse(s).atZone(ZoneId.systemDefault()).toInstant() } catch (ignored) {}

        // Try SQL-ish datetime with space
        try {
            return java.sql.Timestamp.valueOf(s).toInstant()
        } catch (ignored) {}

        return null
    }

    static Map firstOrNull(List<Map> rows) {
        rows ? rows[0] : null
    }

    static String norm(def v) {
        v == null ? null : v.toString().trim()
    }

    static String str(def v) {
        v == null ? '' : v.toString().trim()
    }

    static String up(def v) {
        str(v).toUpperCase()
    }

    static boolean isBlank(def v) {
        v == null || v.toString().trim().isEmpty()
    }

    static boolean isTrue(def v) {
        str(v).equalsIgnoreCase('true')
    }

    static Integer safeInt(def v) {
        if (v == null) return Integer.MAX_VALUE
        try {
            return v as Integer
        } catch (ignored) {
            return Integer.MAX_VALUE
        }
    }
}

/*
Assumptions from your uploaded JSON examples:

1) Each source is shaped like:
   {
     "total": ...,
     "data": [ ... actual rows ... ]
   }

2) Important row values may exist at:
   - row.authorizationnbr
   - row.root.authorizationnbr
   - row.parent.authorizationnbr

3) We want to treat OH_RS_WL_Flow_hist_tst as the second JSON scheme and
   normalize it so the rest of the logic can query it like a table.
*/

class WorklistJsonAdapter {

    static List<Map> extractRows(def payload) {
        if (payload == null) return []
        if (payload instanceof List) return payload as List<Map>
        if (payload instanceof Map && payload.data instanceof List) return payload.data as List<Map>
        return []
    }

    static Map normalizeWorklistRow(Map row) {
        Map root = row.root instanceof Map ? row.root : [:]
        Map parent = row.parent instanceof Map ? row.parent : [:]

        return [
            // keep original row too in case you want raw access later
            _raw                   : row,

            // preferred flattened values
            id                     : firstNonBlank(row.id),
            authorizationnbr       : firstNonBlank(row.authorizationnbr, root.authorizationnbr, parent.authorizationnbr),
            memberId               : firstNonBlank(row.memberId, root.memberId, parent.memberId),
            businessUnitCd         : firstNonBlank(row.businessUnitCd, root.businessUnitCd, parent.businessUnitCd),
            requesMethodDesc       : firstNonBlank(row.requesMethodDesc, root.requesMethodDesc, parent.requesMethodDesc),
            sourceSystem           : firstNonBlank(row.sourceSystem, root.sourceSystem, parent.sourceSystem),
            user                   : firstNonBlank(row.user, root.user, parent.user),
            initiator              : firstNonBlank(row.initiator, root.initiator, parent.initiator),
            status                 : firstNonBlank(row.status, root.status, parent.status),

            // task/case metadata from your JSON examples
            state                  : firstNonBlank(row.state),
            tenantId               : firstNonBlank(row.tenantId),
            scopeId                : firstNonBlank(row.scopeId),
            rootScopeId            : firstNonBlank(row.rootScopeId),
            parentScopeId          : firstNonBlank(row.parentScopeId),
            caseDefinitionName     : firstNonBlank(row.caseDefinitionName),
            caseDefinitionKey      : firstNonBlank(row.caseDefinitionKey, row.parentScopeDefinitionKey),
            taskDefinitionId       : firstNonBlank(row.taskDefinitionId),

            // timestamps differ across payloads
            started                : firstNonBlank(row.started),
            createTime             : firstNonBlank(row.createTime),

            // keep nested objects available
            root                   : root,
            parent                 : parent
        ]
    }

    static List<Map> normalizeRows(def payload) {
        extractRows(payload).collect { normalizeWorklistRow(it as Map) }
    }

    static Map firstMatchByAuthorization(def payload, String authorizationNbr) {
        String target = norm(authorizationNbr)
        if (!target) return null

        return normalizeRows(payload).find { row ->
            norm(row.authorizationnbr) == target
        }
    }

    static List<Map> findAllByAuthorization(def payload, String authorizationNbr) {
        String target = norm(authorizationNbr)
        if (!target) return []

        return normalizeRows(payload).findAll { row ->
            norm(row.authorizationnbr) == target
        }
    }

    static boolean existsByAuthorization(def payload, String authorizationNbr) {
        return firstMatchByAuthorization(payload, authorizationNbr) != null
    }

    static Map buildHistIndex(def histPayload) {
        Map<String, List<Map>> grouped = [:].withDefault { [] }
        normalizeRows(histPayload).each { row ->
            String key = norm(row.authorizationnbr)
            if (key) {
                grouped[key] << row
            }
        }
        return grouped
    }

    static String firstNonBlank(def... values) {
        for (def v : values) {
            if (v != null && v.toString().trim()) {
                return v.toString().trim()
            }
        }
        return null
    }

    static String norm(def v) {
        return v == null ? null : v.toString().trim()
    }
}]]></script>
    </scriptTask>
