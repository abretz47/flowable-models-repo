    <scriptTask id="ScriptTask_1" name="Create Payload" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[import groovy.json.JsonOutput
import java.security.SecureRandom
import java.time.OffsetDateTime
import java.time.format.DateTimeFormatter

// Read targetKB from process var (default 8)
int targetKB = (execution != null && execution.hasVariable('targetKB')) ?
        (execution.getVariable('targetKB') as Integer) : 8
int targetBytes = Math.max(1024, targetKB * 1024)

// Locals inside the script's run(), closures can capture these fine
def rnd = new SecureRandom()
def alpha = (('a'..'z') + ('A'..'Z') + ('0'..'9')).toList()

// Closure instead of method -> can see rnd/alpha
def randStr = { int n ->
    def sb = new StringBuilder(n)
    for (int i = 0; i < n; i++) sb.append(alpha[rnd.nextInt(alpha.size())])
    sb.toString()
}

Map<String, Object> baseObj = [
  app       : "myapp",
  env       : "dev",
  level     : "INFO",
  timestamp : OffsetDateTime.now().format(DateTimeFormatter.ISO_OFFSET_DATE_TIME),
  traceId   : UUID.randomUUID().toString(),
  k8s       : [namespace: "flowable", pod: "myapp-0", node: "worker-1"],
  items     : [],
  padding   : [:]
]

// Helper uses the closure
def newItem = {
  [
    id     : UUID.randomUUID().toString(),
    name   : randStr(24),
    value  : randStr(64),
    tags   : (1..5).collect { randStr(8) },
    nested : [
      code     : randStr(12),
      summary  : randStr(80),
      details  : randStr(160),
      metrics  : [
        latencyMs : rnd.nextInt(2000),
        sizeBytes : rnd.nextInt(500000),
        ok        : rnd.nextBoolean()
      ],
      blobs    : (1..3).collect { randStr(120) }
    ]
  ]
}

String json = JsonOutput.toJson(baseObj)
while (json.getBytes("UTF-8").length < targetBytes) {
  if (rnd.nextBoolean()) {
    baseObj.items << newItem()
  } else {
    def key = "p${baseObj.padding.size()}"
    baseObj.padding[key] = randStr(256 + rnd.nextInt(512))
  }
  json = JsonOutput.toJson(baseObj)
}

// Or: flw.setOutput("bigJson", baseObj) if you want a Map
flw.setOutput("bigJson", baseObj)
]]></script>
    </scriptTask>
