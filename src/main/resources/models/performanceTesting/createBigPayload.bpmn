  <process id="createBigPayload" name="Create Big Payload" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-04-17T20:36:09.363Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-04-17T20:36:09.363Z]]></design:modificationdate>
