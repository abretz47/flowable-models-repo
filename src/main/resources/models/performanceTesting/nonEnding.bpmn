        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[var iteration;


iteration = execution.getVariable("iteration") || 0;

execution.setVariable("iteration" + iteration.toString(), iteration++);]]></script>
