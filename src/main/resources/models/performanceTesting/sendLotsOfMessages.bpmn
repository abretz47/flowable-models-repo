  <process id="sendLotsOfMessages" name="send lots of messages" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <flowable:historyLevel><![CDATA[instance]]></flowable:historyLevel>
      <flowable:processSequence variableName="sequence"><![CDATA[mySequence]]></flowable:processSequence>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-04-20T16:32:22.901Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-04-20T16:32:22.901Z]]></design:modificationdate>
    </extensionElements>
    <serviceTask id="VariableActivity_3" name="Initialize variables" flowable:async="true" flowable:delegateExpression="${initVariablesService}" flowable:extensionId="VariableActivity">
      <extensionElements>
        <flowable:overwrite><![CDATA[true]]></flowable:overwrite>
        <flowable:variableMapping name="iterArray" valueType="jsonArray" value="54"></flowable:variableMapping>
        <design:stencilid><![CDATA[VariableActivity]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="SendEventTask_4" name="Send event task" flowable:type="send-event">
      <extensionElements>
        <flowable:eventType><![CDATA[myMessage]]></flowable:eventType>
        <flowable:eventInParameter source="${sequence + loopCounter}" target="orderid"></flowable:eventInParameter>
        <flowable:eventInParameter source="${sequence + loopCounter}" target="itemid"></flowable:eventInParameter>
        <flowable:eventInParameter source="${bigJson}" target="payload"></flowable:eventInParameter>
        <flowable:channelKey><![CDATA[myOutboundChannel]]></flowable:channelKey>
        <design:stencilid><![CDATA[SendEventTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="true" flowable:collection="${iterArray}" flowable:elementVariable="element">
        <extensionElements></extensionElements>
      </multiInstanceLoopCharacteristics>
    </serviceTask>
    <scriptTask id="ScriptTask_4" name="Generate Big Payload" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[import com.fasterxml.jackson.databind.ObjectMapper
import java.security.SecureRandom
import java.time.OffsetDateTime
import java.time.format.DateTimeFormatter
import java.util.UUID

ObjectMapper mapper = new ObjectMapper()

// Read targetKB from process var (default 8)
int targetKB = 8
if (execution != null && execution.hasVariable('targetKB')) {
    Object raw = execution.getVariable('targetKB')
    if (raw instanceof Number) {
        targetKB = ((Number) raw).intValue()
    } else if (raw != null) {
        targetKB = Integer.parseInt(raw.toString())
    }
}

int targetBytes = Math.max(1024, targetKB * 1024)

SecureRandom rnd = new SecureRandom()
List<String> alpha = []
alpha.addAll(('a'..'z').collect { it.toString() })
alpha.addAll(('A'..'Z').collect { it.toString() })
alpha.addAll(('0'..'9').collect { it.toString() })

def randStr = { int n ->
    StringBuilder sb = new StringBuilder(n)
    for (int i = 0; i < n; i++) {
        sb.append(alpha.get(rnd.nextInt(alpha.size())))
    }
    sb.toString()
}

Map<String, Object> baseObj = [
    app      : 'myapp',
    env      : 'dev',
    level    : 'INFO',
    timestamp: OffsetDateTime.now().format(DateTimeFormatter.ISO_OFFSET_DATE_TIME),
    traceId  : UUID.randomUUID().toString(),
    k8s      : [
        namespace: 'flowable',
        pod      : 'myapp-0',
        node     : 'worker-1'
    ],
    items    : [],
    padding  : [:]
]

def newItem = {
    [
        id    : UUID.randomUUID().toString(),
        name  : randStr(24),
        value : randStr(64),
        tags  : (1..5).collect { randStr(8) },
        nested: [
            code   : randStr(12),
            summary: randStr(80),
            details: randStr(160),
            metrics: [
                latencyMs: rnd.nextInt(2000),
                sizeBytes: rnd.nextInt(500000),
                ok       : rnd.nextBoolean()
            ],
            blobs  : (1..3).collect { randStr(120) }
        ]
    ]
}

byte[] jsonBytes = mapper.writeValueAsBytes(baseObj)
while (jsonBytes.length < targetBytes) {
    if (rnd.nextBoolean()) {
        ((List) baseObj.items).add(newItem())
    } else {
        String key = "p" + ((Map) baseObj.padding).size()
        ((Map) baseObj.padding).put(key, randStr(256 + rnd.nextInt(512)))
    }
    jsonBytes = mapper.writeValueAsBytes(baseObj)
}

String json = new String(jsonBytes, 'UTF-8')
flw.setOutput('bigJson', json)]]></script>
    </scriptTask>
