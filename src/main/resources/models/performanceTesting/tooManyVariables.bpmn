    <scriptTask id="ScriptTask_13" name="Create Flat Variables" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
      <script><![CDATA[/*
 * Flowable Groovy Script: Flatten JSON to local variables (scoping-safe)
 * Fix: use @Field for script-level vars so methods/closures can access them.
 */

import groovy.json.JsonSlurper
import groovy.transform.Field

// ---- configuration ----
@Field String INPUT_VAR = 'bigJson'  // change to your incoming variable name
@Field String BASE_KEY  = 'json'       // prefix for created variables
// -----------------------

// sanitizer for variable name segments
String sanitize(String s) {
  def t = (s ?: "")
    .replaceAll('[^A-Za-z0-9_]', '_')
    .replaceAll('_{2,}', '_')
  t = t.replaceAll('^_+','').replaceAll('_+$','')
  return t ? t : 'x'
}

// join path with underscores under BASE_KEY
String makeVarName(List<String> parts) {
  def sanitized = parts.collect { sanitize(it) }
  return ([BASE_KEY] + sanitized).join('_')
}

// Decide what counts as a "leaf"
boolean isLeaf(Object v) {
  !(v instanceof Map) && !(v instanceof List)
}

// Recursively walk
void walk(Object node, List<String> path) {
  if (node instanceof Map) {
    // Uncomment to also store whole objects:
    // execution.setVariableLocal(makeVarName(path), node)
    node.each { k, v -> walk(v, path + [k?.toString()]) }
  } else if (node instanceof List) {
    // Uncomment to also store whole arrays:
    // execution.setVariableLocal(makeVarName(path), node)
    int i = 0
    node.each { v ->
      walk(v, path + [String.valueOf(i)])
      i++
    }
  } else {
    flw.setOutput(makeVarName(path), node)
  }
}

// ---- load/parse input ----
def raw = execution.getVariable(INPUT_VAR)
if (raw == null) {
  throw new IllegalArgumentException("Variable '${INPUT_VAR}' not found or null.")
}

def root
if (raw instanceof Map || raw instanceof List) {
  root = raw
} else {
  def asText = raw.toString()
  if (!asText?.trim()) {
    throw new IllegalArgumentException("Variable '${INPUT_VAR}' is empty.")
  }
  root = new JsonSlurper().parseText(asText)
}

// ---- go! ----
walk(root, [])
]]></script>
